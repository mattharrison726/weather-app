# Open-Meteo is free and requires no API key.
# Set the location you want to track weather for.
WEATHER_LATITUDE=51.5074
WEATHER_LONGITUDE=-0.1278
WEATHER_LOCATION_NAME=London

# Backend server port
PORT=8000

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite:///./data/weather.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Automatic background scheduler (off by default).
# Use POST /api/pipeline/trigger for on-demand refreshes instead.
# Set to true to enable scheduled ingestion.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_HOURS=6
